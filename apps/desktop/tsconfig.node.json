{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ai-workbench/core": [
        "../../packages/core/src/index.ts"
      ],
      "@ai-workbench/core/*": [
        "../../packages/core/src/*"
      ]
    },
    "types": [
      "node",
      "electron-vite/node"
    ]
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*"
  ]
}
