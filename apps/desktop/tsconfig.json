{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@ai-workbench/core": [
        "../../packages/core/src/index.ts"
      ],
      "@ai-workbench/core/*": [
        "../../packages/core/src/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ]
    }
  },
  "include": [
    "src/renderer/src/**/*"
  ]
}
