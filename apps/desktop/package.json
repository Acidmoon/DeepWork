{
  "name": "@ai-workbench/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "validate:workspace-regression": "node validation/workspace-regression/run-workspace-regression.mjs",
    "validate:workspace-web-capture": "node validation/workspace-web-capture/run-workspace-web-capture-validation.mjs",
    "validate:workspace-retrieval": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File validation/workspace-retrieval/run-workspace-retrieval-validation.ps1",
    "validate:custom-web-panels": "node validation/custom-web-panels/run-custom-web-panels-validation.mjs",
    "validate:terminal-panel-configuration": "node validation/terminal-panel-configuration/run-terminal-panel-configuration-validation.mjs",
    "validate:renderer-entrypoint": "node validation/renderer-entrypoint.mjs",
    "validate:internal-alpha": "npm run typecheck && npm run validate:workspace-retrieval && npm run build && npm run validate:renderer-entrypoint && npm run validate:workspace-regression && npm run validate:workspace-web-capture && npm run validate:custom-web-panels && npm run validate:terminal-panel-configuration"
  },
  "dependencies": {
    "@ai-workbench/core": "0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.2.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
