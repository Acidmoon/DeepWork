{
  "name": "ai-workbench",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ai-workbench/desktop",
    "build": "npm run build -w @ai-workbench/desktop",
    "rebuild:native": "npm run rebuild:native -w @ai-workbench/desktop",
    "typecheck": "npm run typecheck -w @ai-workbench/desktop",
    "validate:workspace-regression": "npm run validate:workspace-regression -w @ai-workbench/desktop",
    "validate:workspace-web-capture": "npm run validate:workspace-web-capture -w @ai-workbench/desktop",
    "validate:workspace-retrieval": "npm run validate:workspace-retrieval -w @ai-workbench/desktop",
    "validate:custom-web-panels": "npm run validate:custom-web-panels -w @ai-workbench/desktop",
    "validate:terminal-panel-configuration": "npm run validate:terminal-panel-configuration -w @ai-workbench/desktop",
    "validate:terminal-behavior": "npm run validate:terminal-behavior -w @ai-workbench/desktop",
    "validate:workspace-profiles": "npm run validate:workspace-profiles -w @ai-workbench/desktop",
    "validate:visual-smoke": "npm run validate:visual-smoke -w @ai-workbench/desktop",
    "validate:renderer-entrypoint": "npm run validate:renderer-entrypoint -w @ai-workbench/desktop",
    "validate:internal-alpha": "npm run validate:internal-alpha -w @ai-workbench/desktop"
  }
}
